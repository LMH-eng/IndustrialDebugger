####### Install

install_target: first FORCE
	@if not exist E:$(INSTALL_ROOT:@msyshack@%=%)\IndustrialDebugger\bin mkdir E:$(INSTALL_ROOT:@msyshack@%=%)\IndustrialDebugger\bin & if not exist E:$(INSTALL_ROOT:@msyshack@%=%)\IndustrialDebugger\bin exit 1
	-$(INSTALL_FILE) $(DESTDIR_TARGET) E:$(INSTALL_ROOT:@msyshack@%=%)\IndustrialDebugger\bin\$(TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) E:$(INSTALL_ROOT:@msyshack@%=%)\IndustrialDebugger\bin\$(TARGET)
	-$(DEL_DIR) E:$(INSTALL_ROOT:@msyshack@%=%)\IndustrialDebugger\bin 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

